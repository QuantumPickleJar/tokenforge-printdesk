# TokenForge PrintDesk — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or real secrets to version control.

# Supabase project URL (from your Supabase project settings)
VITE_SUPABASE_URL=

# Supabase anonymous/public key (from your Supabase project settings)
VITE_SUPABASE_ANON_KEY=

# Optional local/demo owner unlock fallback.
# Use only on a trusted LAN or Tailnet. Supabase Auth remains the production owner auth path.
VITE_ENABLE_LOCAL_OWNER_UNLOCK=false

# Tailnet HTTPS example when printdesk-gallery-auth is exposed with:
# tailscale serve --bg --https=8443 http://127.0.0.1:5175
# VITE_LOCAL_OWNER_AUTH_URL=https://<pi-full-tailnet-name>:8443
VITE_LOCAL_OWNER_AUTH_URL=
